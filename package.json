{
  "name": "vps-control-room",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "agent:build": "npm --prefix agent run build",
    "frontend:build": "npm --prefix frontend run build",
    "cli:build": "npm --prefix cli run build",
    "build": "npm run convex:deploy && npm run agent:build && npm run frontend:build && npm run cli:build",
    "convex:dev": "npx convex dev --env-file convex/.env.local --typecheck disable",
    "convex:deploy": "npx convex deploy --env-file convex/.env.local --typecheck disable -y",
    "cli:dev": "npm --prefix cli run dev --"
  },
  "dependencies": {
    "convex": "^1.34.0"
  }
}
