# ─── SI CODER — Required Environment Variables ───────────────────────────────
# Copy the values below into ~/.bashrc (or ~/.zshrc) so they are available
# in every terminal session. Run: source ~/.bashrc after editing.
#
# See docs/si-coder-requirements.md for how to obtain each value.
# ─────────────────────────────────────────────────────────────────────────────

# ── Dokploy ──────────────────────────────────────────────────────────────────
# Your Dokploy server URL (no trailing slash, no /api suffix)
# Example: https://dokploy.example.com
DOKPLOY_API_URL=https://<your-dokploy-url>

# API key from Dokploy → Settings → API Keys → Create
DOKPLOY_API_KEY=<your-dokploy-api-key>

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token with repo scope (create repos + push code)
# GitHub → Settings → Developer Settings → Personal access tokens → Fine-grained
# Required scopes: Contents (read/write), Metadata (read), Administration (read/write)
GITHUB_TOKEN=github_pat_<your-github-pat>

# ── Hostinger (optional — enables automatic DNS setup) ────────────────────────
# Hostinger API token for DNS record automation
# Hostinger → API → Generate Token
HOSTINGER_API_TOKEN=<your-hostinger-api-token>

# ── SSH ──────────────────────────────────────────────────────────────────────
# No env var needed — but your server must have an SSH key added to GitHub.
# Test with: ssh -T git@github.com
# If not configured: ssh-keygen -t ed25519 -C "your@email.com"
# Then add the public key at: https://github.com/settings/ssh/new
